# ByTE Report Generator Environment Configuration Template
# Copy this file to .env and fill in your actual credentials

# --- JWT Authentication ---
# Use a strong secret key for production (e.g., generated via 'openssl rand -hex 32')
SECRET_KEY=your_secret_key_here

# --- Email (SMTP) Configuration ---
# Required for user verification. Fallback: verification links printed to terminal.
# Recommendation: Use a Gmail account with an "App Password".
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# --- Cloud Storage (Cloudinary) ---
# Required for storing and serving generated report ZIP files in the cloud.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret